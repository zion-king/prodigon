# =============================================================================
# Production AI System - Environment Configuration
# Dev server: avoid running on public networks (esbuild vulnerability)
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- General ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Groq API ---
GROQ_API_KEY=your-groq-api-key-here
DEFAULT_MODEL=llama-3.3-70b-versatile
MAX_TOKENS=1024
TEMPERATURE=0.7

# --- Service URLs (for local development without Docker) ---
MODEL_SERVICE_URL=http://localhost:8001
WORKER_SERVICE_URL=http://localhost:8002

# --- Service URLs (for Docker) ---
# MODEL_SERVICE_URL=http://model-service:8001
# WORKER_SERVICE_URL=http://worker-service:8002

# --- Database (Postgres) ---
# Chat sessions, messages, and batch jobs are persisted here. Start a local
# Postgres with: `make db-up` (spawns just the postgres service from
# baseline/docker-compose.yml, so bare-metal `make run` still works).
# Apply the schema with: `make db-migrate` (runs `alembic upgrade head`).
DATABASE_URL=postgresql+asyncpg://prodigon:prodigon@localhost:5432/prodigon

# --- Queue ---
# `postgres` uses SELECT ... FOR UPDATE SKIP LOCKED against batch_jobs (durable,
# survives restarts). `memory` is in-process only — useful for unit tests or
# quick demos but loses jobs on restart.
QUEUE_TYPE=postgres
REDIS_URL=redis://localhost:6379/0

# --- API Gateway ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# --- Mock mode (set to true for offline/testing) ---
USE_MOCK=false
